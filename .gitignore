# =====================================================
# PYTHON / FASTAPI BACKEND
# =====================================================

# Python cache
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
.venv/
env/

# Environment variables (secrets)
.env
.env.*
!.env.example

# Logs
*.log

# Local databases
*.sqlite3
*.db

# Test / coverage
.pytest_cache/
.coverage
htmlcov/

# Type checking
.mypy_cache/
.pyre/

# Build files
build/
dist/
*.egg-info/
.eggs/

# =====================================================
# NODE / VITE / REACT FRONTEND
# =====================================================

# Dependencies (VERY IMPORTANT)
node_modules/

# Vite build output
dist/
dist-ssr/

# Cache
.cache/
.vite/
.eslintcache

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment files
frontend/.env
frontend/.env.local
frontend/.env.*.local

# =====================================================
# IDE / EDITOR
